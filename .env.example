# Infisical SDK Test Configuration
# Copy this file to .env and fill in your actual values

# Infisical server URL
INFISICAL_SITE_URL=https://app.infisical.com

# Your Infisical access token (Bearer token)
INFISICAL_ACCESS_TOKEN=your-jwt-token-here

# Project ID (workspace UUID) - found in project settings
INFISICAL_PROJECT_ID=workspace-uuid-here

# Environment slug
INFISICAL_ENVIRONMENT=dev

# Secret names for testing
INFISICAL_SECRET_NAME=c4c_emea_qa_account
